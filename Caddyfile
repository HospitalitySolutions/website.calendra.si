:80 {
  root * /srv
  encode gzip zstd

  # Canonical language-specific URLs. Legacy English aliases redirect to /en/*.
  redir /pricing /en/pricing 308
  redir /mobilna-aplikacija /calendra-connect 308
  redir /mobile-app /en/calendra-connect 308
  redir /en/mobile-app /en/calendra-connect 308
  redir /stranke /narocanje 308
  redir /en/clients /en/booking 308
  redir /clients /en/booking 308
  redir /booking /en/booking 308
  redir /support /en/support 308
  redir /privacy-policy /en/privacy-policy 308
  redir /terms-of-service /en/terms-of-service 308
  redir /legal /en/legal 308
  redir /data-processing-agreement /en/data-processing-agreement 308
  redir /dpa /en/data-processing-agreement 308
  redir /subprocessors /en/subprocessors 308
  redir /cookie-policy /en/cookie-policy 308
  redir /cookies /en/cookie-policy 308
  redir /security /en/security 308
  redir /data-rights /en/data-rights 308
  redir /zoom /en/zoom-integration 308
  redir /zoom-integration /en/zoom-integration 308
  redir /ai-transparency /en/ai-transparency 308
  redir /account-deletion /en/account-deletion 308

  # Vite fingerprints files in /assets, so they can be cached indefinitely.
  @immutableAssets path /assets/*
  header @immutableAssets Cache-Control "public, max-age=31536000, immutable"

  # Public images and icons use stable names and a shorter browser cache.
  @staticImages path /hero/* /reviews/* /favicon.ico /favicon-*.png /apple-touch-icon.png /icon-*.png /calendra-logo.png /og-calendra.png /connect/*
  header @staticImages Cache-Control "public, max-age=604800"

  # Serve any route that was actually prerendered by the build. Unknown paths
  # remain unknown and are returned as 404 by file_server—there is no second
  # manually maintained route whitelist to drift out of sync.
  handle {
    try_files {path}/index.html {path}
    file_server
  }
}
